---
import clasesGrupales from "../../public/images/services/group.webp";
import HomeService from "./service/HomeService.astro";
import Details from "./service/Details.astro";
import { includes_group } from "../data/includes";
import { faqs_group } from "../data/faqs";
import Faqs from "./service/Faqs.astro";
---

<HomeService
    image={clasesGrupales.src}
    title="Clases grupales"
    text="Únete a nuestras clases grupales y disfruta de entrenamientos dinámicos y motivadores, diseñados para mejorar tu condición física en un ambiente social y de apoyo."
/>
<Details includes={includes_group} />
<Faqs content={faqs_group} />
