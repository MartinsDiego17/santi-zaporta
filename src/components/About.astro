---
import Now from "./about/Now.astro";
import Presentation from "./about/Presentation.astro";
import Road from "./about/Road.astro";
---

<article
    id="about"
    class="local-main relative w-screen min-h-screen h-fit cel:h-fit"
>
    <Presentation />
    <Road/>
    <Now />
</article>

<style>
    @media (max-width: 768px) {
        p {
            width: 100%;
            font-size: 1rem;
        }
    }

    @media (min-width: 1536px) {
        p {
            font-size: 1.2rem;
        }
    }
    .local-main::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(
            black,
            transparent,
            transparent,
            transparent,
            transparent,
            transparent
        );
    }
    img {
        padding: 8px;
        filter: brightness(110%);
        transform: rotate(5deg) scale(1.1);
    }
    p span {
        color: var(--light);
    }
    .camino {
        background: linear-gradient(black, rgba(0,0,0,0.3), rgba(0,0,0,0.4)) ,url(../../public/images/about/camino.webp);
        background-position: center center;
        background-repeat: no-repeat;
        background-size: cover;
    }
    .camino::before {
        content: "";
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        backdrop-filter: blur(3px);
    }
</style>
