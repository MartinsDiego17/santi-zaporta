---
import { AccordionFaq } from "./AccordionFaq";
const { content } = Astro.props;
---

<article
    id="questions"
    class="cel:h-fit tab:h-fit tab:mt-[20vh] tab:w-[80%] cel:w-[80%] flex flex-col justify-center place-items-center mt-[20vh] 2xl:mt-[10vh] pb-[20vh] h-screen w-[70%] mx-auto"
>
    <h1
        class="tab:text-[2.5rem] mb-[5vh] cel:text-[1.5rem] cel:w-full lg:text-[1.5rem] 2xl:text-[3.3rem] text-[#ddd] text-[2.5rem] font-semibold"
    >
        Preguntas frecuentes
    </h1>
    <AccordionFaq content={content} client:visible />
</article>
