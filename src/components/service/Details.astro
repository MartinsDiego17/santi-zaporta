---
const { includes } = Astro.props;
interface PropsConfig {
    title: string;
    description: string;
}
---

<article class="content relative w-screen min-h-screen h-[130vh] bg-[#121212] pt-[10%]">
    <h1 class="text-white text-[3rem] font-extrabold relative text-center">¿Qué incluye?</h1>
    <div class="w-[80%] mx-auto grid grid-cols-3 gap-x-4 gap-y-4 mt-[2%]">
        {
            includes?.map((include: PropsConfig, index: number) => (
                <div class="card bg-black px-[7vh] py-[5vh]">
                    <h3 class="mb-[2%] text-[var(--primary)] text-[1.2rem] font-extrabold text-balance">
                        {include.title}
                    </h3>
                    <p class="text-[#ccc] text-pretty text-tiny">
                        {include.description}
                    </p>
                </div>
            ))
        }
    </div>
</article>

<style>
    .card {
        box-shadow: 0px 20px 250px var(--dark);
    }
    .content::before {
        content: "";
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        background: linear-gradient(
            #0f0f0f,
            transparent,
            transparent,
            transparent
        );
    }
</style>
