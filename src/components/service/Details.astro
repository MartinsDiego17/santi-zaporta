---
const { includes } = Astro.props;
interface PropsConfig {
    title: string;
    description: string;
}
---

<article class="content relative w-screen min-h-screen bg-transparent pt-[10%]">
        <h1 class="px-[10vh] text-white text-[3rem] font-extrabold relative text-center">
        ¿Qué incluye? 
    </h1>
    <div class="w-[80%] mx-auto grid grid-cols-3 gap-x-4 gap-y-4 mt-[2%]">
        {
            includes?.map((include: PropsConfig, index: number) => (
                <div class="px-[7vh] py-[5vh]">
                    <h3 class="mb-[2%] text-[var(--primary)] text-[1.2rem] font-extrabold text-balance">
                        {include.title}
                    </h3>
                    <p class="text-[#ccc] text-pretty text-tiny">
                        {include.description}
                    </p>
                </div>
            ))
        }
    </div>
</article>

<style>
    h1 {
        letter-spacing: 2px;
        text-shadow: 0px -10px 120px var(--primary);
    }
    .content::before {
        content: "";
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        background: linear-gradient(
            black,
            transparent,
            transparent,
            transparent
        );
    }
</style>
