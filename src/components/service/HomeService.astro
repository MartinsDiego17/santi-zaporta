---
const { image, title, text } = Astro.props;
---

<section
    class="local-main relative w-screen h-screen flex justify-between place-items-center"
>
    <article class="left relative w-[50%] h-screen">
        <img class="w-full h-full" src={image} />
    </article>
    <article
        class="flex flex-col justify-center place-items-center pb-[5%] w-[50%] h-screen"
    >
        <h2 class="text-left w-[80%] text-white text-[3rem] font-bold">
            {title}
        </h2>
        <p class="w-[60%] mx-auto text-pretty text-right mt-[3vh] text-[#ccc]">
            {text}
        </p>
    </article>
</section>

<style>
    .left::before {
        content: "";
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        background: linear-gradient(to right, transparent, black);
        z-index: 1;
    }
    .local-main::before {
        content: "";
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        background: linear-gradient(transparent, transparent, black);
        z-index: 1;
    }
</style>
